    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Kelola Data Penjualan</h4>
        <div>
            <a href="/penjualan/tambah" class="btn btn-primary btn-sm">Tambah Data Penjualan</a>
        </div>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark text-center">
            <tr>
                <th width="50">No</th>
                <th>No. Faktur</th>
